# APsystems OpenAPI Credentials
# Obtain these by emailing APsystems support

APS_APP_ID=your_32_character_app_id_here_____
APS_APP_SECRET=your12secret

# Optional: Default system identifier (sid) for all API calls
APS_SYS_ID=your_system_id_here

# Optional: Override API base URL
# APS_BASE_URL=https://api.apsystemsema.com:9282

# Optional: Enable web dashboard
APS_DASHBOARD=true
APS_DASH_ADDR_PORT=8080

# Optional: Log level (debug, info, warn, error)
APS_LOG_LEVEL=info
